# ── Supabase ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase Storage ─────────────────────────────────────────────────────
# Create a private bucket called "portal-files" in the Supabase dashboard.
# The API routes use the service role key to upload and generate signed URLs.
NEXT_PUBLIC_STORAGE_BUCKET=portal-files
